# ═══════════════════════════════════════════════════════════════════════════════
# Event AI Ops v2 — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# Most per-campaign credentials can also be set in the DB (campaigns table),
# which takes priority over these env vars.

# ── Core ──────────────────────────────────────────────────────────────────────
PUBLIC_BASE_URL=https://your-app.fly.dev

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Twilio (WhatsApp) ────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
# WHATSAPP_SYSTEM_PROMPT_PATH=app/prompts/whatsapp_system_prompt.txt
# WHATSAPP_SYSTEM_PROMPT=  # Or set the prompt directly as env var

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_VIP_PRICE_ID=price_...
# VIP_PRICE_USA_1=price_...  # 1 VIP x 79 USD
# VIP_PRICE_USA_2=price_...  # 2 VIPs x 97 USD
STRIPE_SUCCESS_URL=https://your-app.fly.dev/vip/success
STRIPE_CANCEL_URL=https://your-app.fly.dev/vip/cancel

# ── Telnyx (Voice Calling / WebRTC) ──────────────────────────────────────────
TELNYX_API_KEY=KEY...
TELNYX_SIP_CONNECTION_ID=your-connection-id
TELNYX_FROM_NUMBER=+1XXXXXXXXXX

# ── ElevenLabs (AI Voice) ────────────────────────────────────────────────────
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=
# ELEVENLABS_TTS_MODEL=eleven_multilingual_v2

# ── Google Sheets ─────────────────────────────────────────────────────────────
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# GSHEET_ALL_LEADS_ID=your-spreadsheet-id
# GSHEET_SALES_LEADS_ID=your-spreadsheet-id

# ── Meta Conversions API ─────────────────────────────────────────────────────
# META_PIXEL_ID=your-pixel-id
# META_CONVERSIONS_API_TOKEN=your-access-token

# ── Auth / Security ──────────────────────────────────────────────────────────
CRON_TOKEN=your-secret-cron-token
SPARTANS_KEY=your-spartans-key
CHECKIN_KEY=your-checkin-key

# ── Event (fallback — DB campaign data takes priority) ────────────────────────
# DEFAULT_EVENT_ID=
# EVENT_NAME=
# EVENT_DATE=
# EVENT_PLACE=
# EVENT_SPEAKERS=
# VIP_PRICE=

# ── Media (optional) ─────────────────────────────────────────────────────────
# WHATSAPP_VIDEO_VIP_PITCH=https://...
# WHATSAPP_VIDEO_TESTIMONIOS=https://...
